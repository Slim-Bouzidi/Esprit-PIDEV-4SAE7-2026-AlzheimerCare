# -------------------------------------------------------------------------
# LOCAL CONFIGURATION OVERRIDES (GIT-IGNORED)
# -------------------------------------------------------------------------
# Copy this file to 'application-local.properties' to customize your local settings.
# Changes in 'application-local.properties' will NOT be committed to git.
# -------------------------------------------------------------------------

# Database Credentials (if different from default root / empty)
# spring.datasource.username=your_db_user
# spring.datasource.password=your_db_password

# Brevo Transactional Email (Required if you want to test email sending)
# BREVO_API_KEY=your_brevo_api_key_here
# BREVO_SENDER_EMAIL=your_verified_sender@email.com
# BREVO_SENDER_NAME=Your Name

# SMTP Credentials (if using GMail or another SMTP instead of Brevo)
# SPRING_MAIL_USERNAME=your_gmail@gmail.com
# SPRING_MAIL_PASSWORD=your_app_password

# Support Network Admin Email (where alerts are sent)
# support.network.mail.admin-email=admin@example.com

# -------------------------------------------------------------------------
# LOCAL DEV EUREKA FIX (IMPORTANT for multi-homed machines)
# -------------------------------------------------------------------------
# On dev machines with multiple network adapters (WiFi, Hyper-V, VirtualBox, etc.),
# Spring picks the first non-loopback IP (e.g. 192.168.x.x) for Eureka registration.
# This causes the API Gateway to route requests to a different network interface → CORS failures.
# Uncomment these two lines to force registration on localhost when running locally:
# eureka.instance.ip-address=127.0.0.1
# eureka.instance.hostname=localhost
# In Kubernetes: do NOT set these (leave them commented out in the container env).
# The pod has only one non-loopback interface so prefer-ip-address picks the pod IP correctly.
